{
  "name": "command-center-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "server:build": "npm run build --prefix server",
    "server:dev": "npm run start:dev --prefix server",
    "server:deploy": "cd server && npm run deploy:full",
    "web:build": "npm run build --prefix web",
    "web:dev": "npm run dev --prefix web",
    "web:deploy": "npm run deploy --prefix web",
    "desktop:install": "npm install --prefix desktop",
    "desktop:start": "npm start --prefix desktop",
    "desktop:build:mac": "npm run build:mac --prefix desktop",
    "desktop:build:win": "npm run build:win --prefix desktop",
    "desktop:build:all": "npm run build:all --prefix desktop"
  }
}
